# ─── Apple Wallet ────────────────────────────────────────────────────────────

# Pass Type ID registered in Apple Developer portal
APPLE_PASS_TYPE_ID=pass.com.passto.license

# Team ID from Apple Developer portal (visible in top-right of developer.apple.com)
APPLE_TEAM_ID=76J36374T7

# Password set when exporting the .p12 signing certificate
APPLE_CERT_PASSWORD=your_p12_export_password_here

# Signer certificate in PEM format, base64-encoded
# To generate: openssl pkcs12 -in passto-pass-signing.p12 -clcerts -nokeys -out signerCert.pem -passin pass:PASSWORD
# Then: base64 -i signerCert.pem | tr -d '\n'
APPLE_CERT_PEM_BASE64=

# Signer private key in PEM format, base64-encoded
# To generate: openssl pkcs12 -in passto-pass-signing.p12 -nocerts -nodes -out signerKey.pem -passin pass:PASSWORD
# Then: base64 -i signerKey.pem | tr -d '\n'
APPLE_KEY_PEM_BASE64=

# Apple WWDR G4 certificate in PEM format, base64-encoded
# Download from: apple.com/certificateauthority (Worldwide Developer Relations — G4)
# The downloaded file is a .cer — convert: openssl x509 -inform der -in AppleWWDRCAG4.cer -out wwdr.pem
# Then: base64 -i wwdr.pem | tr -d '\n'
APPLE_WWDR_PEM_BASE64=

# ─── Google Wallet ────────────────────────────────────────────────────────────

# Full contents of the Google Cloud service account JSON key file
# Paste the entire JSON on a single line (or use Vercel's env var editor which handles multiline)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Numeric issuer ID from Google Pay & Wallet Console
# Found at: pay.google.com/business/console → hover over issuer name
GOOGLE_WALLET_ISSUER_ID=3388000000000000000

# Class ID suffix — must match what you created in Google Wallet Console
# Full Class ID will be: {ISSUER_ID}.{CLASS_ID}
GOOGLE_WALLET_CLASS_ID=passto_nurse_license_v1

# ─── PassTo Assets ───────────────────────────────────────────────────────────

# Public URL for PassTo logo image used on Google Wallet passes
# Must be publicly accessible (no auth). Recommended: 660x660px PNG.
PASSTO_LOGO_URL=https://passto.com/assets/logo-wallet.png

# ─── Vercel Blob ─────────────────────────────────────────────────────────────

# Set automatically by Vercel when Blob storage is enabled on the project.
# Do NOT set this manually — enable Blob in the Vercel dashboard instead.
BLOB_READ_WRITE_TOKEN=
