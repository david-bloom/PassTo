curl -X GET 'https://nurse-license-verification.p.rapidapi.com/search?state=NY&name=Smith' \
  -H 'X-RapidAPI-Key: YOUR_RAPIDAPI_KEY' \
  -H 'X-RapidAPI-Host: nurse-license-verification.p.rapidapi.com'
