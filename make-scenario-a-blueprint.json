                      "mapper": {
                        "baseId": "appu4draYRRn3tXjV",
                        "tableId": "tbl0HIA3rtGVKbhZs",
                        "fields": {
                          "Nurse Name": "{{1.firstName}} {{1.lastName}}",
                          "Email": "{{1.email}}",
                          "IDme_Verification_Status": "Verified",
                          "IDme Subject": "{{1.idmeSubject}}",
                          "Account Tier": "Free",
