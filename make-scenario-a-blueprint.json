      "version": 1,
      "parameters": {},
      "mapper": {},
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      },
      "routes": [
        {
          "label": "ID.me Verified",
          "filter": {
            "name": "IDme Verified = true",
            "conditions": [
              [
                {
                  "a": "{{1.idmeVerified}}",
                  "b": "true",
                  "o": "boolean:equal"
