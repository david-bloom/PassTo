                "data": "{\"From\":\"ops@passto.com\",\"To\":\"REPLACE_WITH_OPS_ALERT_EMAIL\",\"Subject\":\"PassTo Alert — ID.me Verification Incomplete\",\"TextBody\":\"Enrollment received but ID.me verification was not completed. No Airtable records created.\\n\\nName: {{1.firstName}} {{1.lastName}}\\nEmail: {{1.email}}\\nLicense #: {{1.licenseNumber}}\\nTimestamp: {{now}}\"}"
