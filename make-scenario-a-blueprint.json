                    "name": "x-oapi-key",
                    "value": "BRJF4D6U646A5PNMIB77AAW9544QFQKAYAEWI9EPU0TNP72CEEO3L4KGVN5K3R44"
                  }
                ],
                "qs": [
                  {
                    "name": "licenseNumber",
                    "value": "{{1.licenseNumber}}"
                  },
                  {
                    "name": "professionCode",
                    "value": "{{1.professionCode}}"
                  }
                ],
                "bodyType": "raw",
                "parseResponse": true,
                "timeout": "30",
                "followRedirect": true,
                "gzip": true,
                "rejectUnauthorized": true,
                "contentType": "application/json",
