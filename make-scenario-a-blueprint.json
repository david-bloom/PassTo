                        "parseResponse": true,
                        "timeout": "30",
                        "followRedirect": true,
                        "gzip": true,
                        "rejectUnauthorized": true,
                        "contentType": "application/json",
                        "data": "{\"From\":\"ops@passto.com\",\"To\":\"REPLACE_WITH_OPS_ALERT_EMAIL\",\"Subject\":\"PassTo Alert — License Flagged\",\"TextBody\":\"License verification flagged. No credential issued.\\n\\nNurse: {{1.firstName}} {{1.lastName}}\\nEmail: {{1.email}}\\nLicense #: {{1.licenseNumber}}\\nNYSED Status: {{3.data.status.value}}\\nEnforcement Actions: {{3.data.enforcementActions}}\\n\\nAirtable Nurse ID: {{12.id}}\\nAirtable License ID: {{13.id}}\\nTimestamp: {{now}}\"}"
                      },
                      "metadata": {
