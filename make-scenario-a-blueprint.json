                      "mapper": {
                        "url": "https://api.postmarkapp.com/email",
                        "serializeUrl": false,
                        "method": "post",
                        "headers": [
                          {
                            "name": "Accept",
                            "value": "application/json"
                          },
                          {
                            "name": "Content-Type",
                            "value": "application/json"
                          },
                          {
                            "name": "X-Postmark-Server-Token",
                            "value": "REPLACE_WITH_POSTMARK_SERVER_TOKEN"
