                  "filter": {
                    "name": "NYSED Status = Registered",
                    "conditions": [
                      [
                        {
                          "a": "{{3.data.status.value}}",
                          "b": "Registered",
                          "o": "text:equal"
                        }
                      ]
                    ]
                  },
                  "flow": [
